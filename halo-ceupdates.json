[
  {
    "UpdateStageName": "Download SAPP CE Server Template",
    "UpdateSourcePlatform": "Linux",
    "UpdateSource": "FetchURL",
    "UpdateSourceData": "https://github.com/Chalwk/SPCLib/releases/download/sapp-server-templates/SAPP_CE.zip",
    "UpdateSourceTarget": "{{$FullBaseDir}}",
    "UnzipUpdateSource": true,
    "OverwriteExistingFiles": false,
    "DeleteAfterExtract": true,
    "SkipOnFailure": false,
    "OneShot": true
  },
  {
    "UpdateStageName": "Initialize 32-bit Wine Prefix",
    "UpdateSourcePlatform": "Linux",
    "UpdateSource": "Executable",
    "UpdateSourceData": "/bin/bash",
    "UpdateSourceArgs": "-c \"WINEPREFIX=\\\"{{$FullRootDir}}.wine\\\" WINEARCH=win32 WINEDEBUG=-all /usr/bin/wineboot --init\"",
    "SkipOnFailure": false,
    "OneShot": true
  },
  {
    "UpdateStageName": "Download AMP Halo Init Template",
    "UpdateSourcePlatform": "All",
    "UpdateSource": "FetchURL",
    "UpdateSourceData": "https://raw.githubusercontent.com/champeau87/amp-halo-sapp/main/halo-ce-AMP-init.txt",
    "UpdateSourceArgs": "AMP_init.txt",
    "UpdateSourceTarget": "{{$FullBaseDir}}",
    "OverwriteExistingFiles": true,
    "SkipOnFailure": false
  },
  {
    "UpdateStageName": "Download AMP SAPP Init Template",
    "UpdateSourcePlatform": "All",
    "UpdateSource": "FetchURL",
    "UpdateSourceData": "https://raw.githubusercontent.com/champeau87/amp-halo-sapp/main/halo-ce-AMP-sapp-init.txt",
    "UpdateSourceArgs": "AMP_sapp_init.txt",
    "UpdateSourceTarget": "{{$FullBaseDir}}",
